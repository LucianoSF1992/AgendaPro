@page
@model ResetPasswordConfirmationModel

@{
    ViewData["Title"] = "Senha redefinida";
}

<section class="py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5 text-center">
                    <span class="badge bg-success-subtle text-success mb-3 px-3 py-2 rounded-pill">
                        Operação concluída
                    </span>

                    <h1 class="h3 fw-bold mb-3">Senha redefinida com sucesso</h1>

                    <p class="text-muted mb-4">
                        Sua senha foi alterada. Agora você já pode entrar no sistema com a nova senha.
                    </p>

                    <a asp-page="./Login" class="btn btn-primary px-4">
                        Ir para o login
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>