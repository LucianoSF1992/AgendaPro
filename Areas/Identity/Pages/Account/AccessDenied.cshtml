@page
@model AccessDeniedModel

@{
    ViewData["Title"] = "Acesso negado";
}

<section class="py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5 text-center">
                    <span class="badge bg-danger-subtle text-danger mb-3 px-3 py-2 rounded-pill">
                        Permissão insuficiente
                    </span>

                    <h1 class="h3 fw-bold mb-3">Acesso negado</h1>

                    <p class="text-muted mb-4">
                        Você não possui permissão para acessar este recurso no AgendaPro.
                    </p>

                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
                            Ir para o início
                        </a>
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary px-4">
                            Ir para o dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>