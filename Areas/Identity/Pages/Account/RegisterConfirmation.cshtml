@page
@model RegisterConfirmationModel

@{
    ViewData["Title"] = "Confirmação de cadastro";
}

<section class="py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-9 col-lg-7">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5 text-center">
                    <span class="badge bg-primary-subtle text-primary mb-3 px-3 py-2 rounded-pill">
                        Conta criada
                    </span>

                    <h1 class="h3 fw-bold mb-3">Confirmação de cadastro</h1>

                    @if (Model.DisplayConfirmAccountLink)
                    {
                        <p class="text-muted mb-4">
                            O sistema ainda não está configurado com um serviço real de envio de e-mails.
                            Para fins de desenvolvimento, utilize o link abaixo para confirmar sua conta.
                        </p>

                        <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn btn-primary px-4">
                            Confirmar conta
                        </a>
                    }
                    else
                    {
                        <p class="text-muted mb-4">
                            Seu cadastro foi realizado com sucesso. Verifique seu e-mail para confirmar sua conta antes de
                            acessar o sistema.
                        </p>

                        <a asp-page="./Login" class="btn btn-outline-primary px-4">
                            Ir para o login
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</section>