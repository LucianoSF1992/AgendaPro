@page
@model ForgotPasswordConfirmation

@{
    ViewData["Title"] = "E-mail enviado";
}

<section class="py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5 text-center">
                    <span class="badge bg-primary-subtle text-primary mb-3 px-3 py-2 rounded-pill">
                        Recuperação de acesso
                    </span>

                    <h1 class="h3 fw-bold mb-3">Verifique seu e-mail</h1>

                    <p class="text-muted mb-4">
                        Enviamos as instruções para redefinição de senha. Verifique sua caixa de entrada e siga o link
                        recebido.
                    </p>

                    <a asp-page="./Login" class="btn btn-outline-primary px-4">
                        Voltar para o login
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>