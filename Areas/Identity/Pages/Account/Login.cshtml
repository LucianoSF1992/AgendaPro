@page
@model LoginModel

@{
    ViewData["Title"] = "Entrar";
}

<section class="py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <span class="badge bg-primary-subtle text-primary mb-3 px-3 py-2 rounded-pill">
                            Acesso ao sistema
                        </span>
                        <h1 class="h3 fw-bold mb-2">Entrar no AgendaPro</h1>
                        <p class="text-muted mb-0">
                            Informe seu e-mail e senha para acessar o sistema.
                        </p>
                    </div>

                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label">E-mail</label>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username"
                                   aria-required="true" placeholder="seuemail@exemplo.com" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label">Senha</label>
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password"
                                   aria-required="true" placeholder="Digite sua senha" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label" asp-for="Input.RememberMe">
                                Lembrar de mim
                            </label>
                        </div>

                        <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-lg">
                            Entrar
                        </button>

                        <div class="mt-4 d-flex flex-column gap-2 text-center">
                            <a id="forgot-password" asp-page="./ForgotPassword">
                                Esqueceu sua senha?
                            </a>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                                Criar nova conta
                            </a>
                            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">
                                Reenviar confirmação de e-mail
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}