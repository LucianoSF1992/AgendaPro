@model IEnumerable<AgendaPro.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Clientes</h1>
        <a asp-action="Create" class="btn btn-primary">+ Novo Cliente</a>
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">@TempData["Sucesso"]</div>
    }

    <form method="get" class="row g-2 mb-4">
        <div class="col-md-6">
            <input type="text" name="busca" value="@ViewBag.Busca" class="form-control"
                   placeholder="Buscar por nome ou telefone" />
        </div>
        <div class="col-md-auto">
            <button type="submit" class="btn btn-outline-secondary">Buscar</button>
        </div>
        <div class="col-md-auto">
            <a asp-action="Index" class="btn btn-outline-dark">Limpar</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Telefone</th>
                    <th>E-mail</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nome</td>
                            <td>@item.Telefone</td>
                            <td>@item.Email</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Detalhes</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center">Nenhum cliente encontrado.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>