@model AgendaPro.Models.Cliente

@{
    ViewData["Title"] = "Detalhes do Cliente";
}

<div class="container py-4">
    <h1 class="mb-4">Detalhes do Cliente</h1>

    <dl class="row">
        <dt class="col-sm-3">Nome</dt>
        <dd class="col-sm-9">@Model.Nome</dd>

        <dt class="col-sm-3">Telefone</dt>
        <dd class="col-sm-9">@Model.Telefone</dd>

        <dt class="col-sm-3">E-mail</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">Observações</dt>
        <dd class="col-sm-9">@Model.Observacoes</dd>
    </dl>

    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</div>