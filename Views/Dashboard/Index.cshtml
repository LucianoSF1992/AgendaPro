@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-4">
    <div class="mb-4">
        <h1 class="mb-1">Dashboard</h1>
        <p class="text-muted">Bem-vindo ao AgendaPro.</p>
    </div>

    <div class="row g-4">
        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100 rounded-4">
                    <div class="card-body">
                        <h5 class="card-title">Clientes</h5>
                        <p class="card-text">Gerencie os clientes cadastrados no sistema.</p>
                        <a asp-controller="Clientes" asp-action="Index" class="btn btn-primary">Acessar clientes</a>
                    </div>
                </div>
            </div>
        }

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100 rounded-4">
                <div class="card-body">
                    <h5 class="card-title">Agenda</h5>
                    <p class="card-text">Em breve: visualização dos agendamentos do dia.</p>
                    <button class="btn btn-outline-secondary" disabled>Em desenvolvimento</button>
                </div>
            </div>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100 rounded-4">
                    <div class="card-body">
                        <h5 class="card-title">Serviços</h5>
                        <p class="card-text">Em breve: cadastro de serviços prestados.</p>
                        <button class="btn btn-outline-secondary" disabled>Em desenvolvimento</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>