@model AgendaPro.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<section class="py-2">
    <div class="agendapro-section-header mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <span class="badge bg-primary-subtle text-primary mb-2 px-3 py-2 rounded-pill">
                    Painel principal
                </span>
                <h1 class="mb-1">Dashboard</h1>
                <p class="text-muted mb-0">
                    Acompanhe os indicadores do dia, visualize os próximos atendimentos e acesse rapidamente os
                    principais
                    módulos.
                </p>
            </div>

            <div class="text-lg-end">
                <div class="text-muted small">Data de referência</div>
                <div class="fw-semibold">@Model.DataReferencia.ToString("dd/MM/yyyy")</div>
            </div>
        </div>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <form method="get" asp-action="Index" class="row g-3 align-items-end">
                    <div class="col-12 col-md-6 col-lg-4">
                        <label asp-for="ProfissionalId" class="form-label fw-semibold">Filtrar por profissional</label>
                        <select asp-for="ProfissionalId" asp-items="Model.Profissionais" class="form-select">
                            <option value="">Todos os profissionais</option>
                        </select>
                    </div>

                    <div class="col-12 col-sm-auto">
                        <button type="submit" class="btn btn-primary w-100">
                            Filtrar
                        </button>
                    </div>

                    <div class="col-12 col-sm-auto">
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">
                            Limpar filtro
                        </a>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="row g-4 mb-4">
        <div class="col-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="text-muted small mb-2">Agendamentos de hoje</div>
                    <div class="display-6 fw-bold">@Model.TotalAgendamentosHoje</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="text-muted small mb-2">Agendados</div>
                    <div class="display-6 fw-bold text-warning">@Model.TotalAgendadosHoje</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="text-muted small mb-2">Concluídos</div>
                    <div class="display-6 fw-bold text-success">@Model.TotalConcluidosHoje</div>
                </div>
            </div>
        </div>

        <div class="col-6 col-xl-3">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="text-muted small mb-2">Cancelados</div>
                    <div class="display-6 fw-bold text-danger">@Model.TotalCanceladosHoje</div>
                </div>
            </div>
        </div>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <div class="text-muted small mb-2">Total de clientes</div>
                        <div class="display-6 fw-bold">@Model.TotalClientes</div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <div class="text-muted small mb-2">Total de serviços</div>
                        <div class="display-6 fw-bold">@Model.TotalServicos</div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <div class="text-muted small mb-2">Total de profissionais</div>
                        <div class="display-6 fw-bold">@Model.TotalProfissionais</div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row g-4 mb-4">
        <div class="col-xl-7">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div
                        class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3">
                        <h5 class="fw-bold mb-0">Próximos atendimentos</h5>
                        <a asp-controller="Agendamentos" asp-action="Index" class="btn btn-sm btn-outline-primary">
                            Ver agenda completa
                        </a>
                    </div>

                    @if (Model.ProximosAtendimentos.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Hora</th>
                                        <th>Cliente</th>
                                        <th>Serviço</th>
                                        <th>Profissional</th>
                                        <th class="text-center">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.ProximosAtendimentos)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@item.HoraInicio.ToString(@"hh\:mm")</td>
                                            <td>@item.Cliente.Nome</td>
                                            <td>@item.Servico.Nome</td>
                                            <td>@(item.Profissional.NomeCompleto ?? item.Profissional.Email)</td>
                                            <td class="text-center">
                                                @switch (item.Status)
                                                {
                                                    case "Agendado":
                                                        <span class="badge bg-warning text-dark">Agendado</span>
                                                        break;
                                                    case "Concluido":
                                                    case "Concluído":
                                                        <span class="badge bg-success">Concluído</span>
                                                        break;
                                                    case "Cancelado":
                                                        <span class="badge bg-danger">Cancelado</span>
                                                        break;
                                                    default:
                                                        <span class="badge bg-secondary">@item.Status</span>
                                                        break;
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            Não há próximos atendimentos para hoje.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-xl-5">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Acesso rápido</h5>

                    <div class="d-grid gap-3">
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Agendamentos" asp-action="Create" class="btn btn-primary">
                                Novo agendamento
                            </a>
                        }

                        <a asp-controller="Agendamentos" asp-action="Index" class="btn btn-outline-primary">
                            Gerenciar agendamentos
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Clientes" asp-action="Index" class="btn btn-outline-secondary">
                                Gerenciar clientes
                            </a>

                            <a asp-controller="Servicos" asp-action="Index" class="btn btn-outline-secondary">
                                Gerenciar serviços
                            </a>

                            <a asp-controller="Profissionais" asp-action="Index" class="btn btn-outline-secondary">
                                Gerenciar profissionais
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
                <h5 class="fw-bold mb-0">Agenda de hoje</h5>
                <span class="text-muted small">@Model.TotalAgendamentosHoje registro(s)</span>
            </div>

            @if (Model.AgendamentosHoje.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Hora</th>
                                <th>Cliente</th>
                                <th>Serviço</th>
                                <th>Profissional</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.AgendamentosHoje)
                            {
                                <tr>
                                    <td class="fw-semibold">
                                        @item.HoraInicio.ToString(@"hh\:mm") - @item.HoraFim.ToString(@"hh\:mm")
                                    </td>
                                    <td>@item.Cliente.Nome</td>
                                    <td>@item.Servico.Nome</td>
                                    <td>@(item.Profissional.NomeCompleto ?? item.Profissional.Email)</td>
                                    <td class="text-center">
                                        @switch (item.Status)
                                        {
                                            case "Agendado":
                                                <span class="badge bg-warning text-dark">Agendado</span>
                                                break;
                                            case "Concluido":
                                            case "Concluído":
                                                <span class="badge bg-success">Concluído</span>
                                                break;
                                            case "Cancelado":
                                                <span class="badge bg-danger">Cancelado</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@item.Status</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    Nenhum agendamento encontrado para hoje.
                </div>
            }
        </div>
    </div>
</section>