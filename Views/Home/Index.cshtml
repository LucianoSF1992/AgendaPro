@{
    ViewData["Title"] = "Início";
}

<section class="py-5">
    <div class="row align-items-center g-4 mb-5">
        <div class="col-lg-7">
            <span class="badge bg-primary-subtle text-primary mb-3 px-3 py-2 rounded-pill">
                Sistema de agendamento de serviços
            </span>

            <h1 class="display-5 fw-bold mb-3">AgendaPro</h1>

            <p class="lead text-muted mb-4">
                Organize clientes, profissionais, serviços e atendimentos em um sistema web moderno,
                prático e pensado para a rotina de negócios que trabalham com agendamentos.
            </p>

            <div class="d-flex flex-wrap gap-2">
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg px-4">
                    Entrar no sistema
                </a>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                        Ir para o Dashboard
                    </a>
                }
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">O que o AgendaPro oferece</h5>

                    <div class="d-flex flex-column gap-3">
                        <div>
                            <h6 class="mb-1">Gestão de clientes</h6>
                            <p class="text-muted mb-0">Cadastre e acompanhe clientes com rapidez e organização.</p>
                        </div>

                        <div>
                            <h6 class="mb-1">Controle de serviços</h6>
                            <p class="text-muted mb-0">Defina duração, valor padrão e detalhes dos serviços prestados.</p>
                        </div>

                        <div>
                            <h6 class="mb-1">Agenda profissional</h6>
                            <p class="text-muted mb-0">Visualize horários, acompanhe atendimentos e evite conflitos.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold">Clientes</h5>
                    <p class="card-text text-muted mb-0">
                        Cadastre e gerencie clientes com rapidez, organização e facilidade no dia a dia.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold">Serviços</h5>
                    <p class="card-text text-muted mb-0">
                        Controle duração, valor padrão e informações importantes de cada serviço.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold">Agendamentos</h5>
                    <p class="card-text text-muted mb-0">
                        Visualize e acompanhe os agendamentos de forma prática e organizada.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>