<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AgendaPro</title>
    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AgendaPro.styles.css" asp-append-version="true" />
</head>

<body class="agendapro-body">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark agendapro-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    AgendaPro
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Alternar navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 mt-3 mt-lg-0">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Servicos" asp-action="Index">Serviços</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Profissionais" asp-action="Index">Profissionais</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Agendamentos" asp-action="Index">Agendamentos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Relatorios" asp-action="Index">Relatórios</a>
                            </li>
                        }
                        else if (User.IsInRole("Profissional"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Agendamentos" asp-action="Index">Agendamentos</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-lg-center mt-3 mt-lg-0">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-lg-2 mb-2 mb-lg-0">
                                <span class="nav-link agendapro-user text-break">
                                    Olá, @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-light btn-sm px-3 w-100">
                                        Sair
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm px-3" asp-area="Identity" asp-page="/Account/Login">
                                    Entrar
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="agendapro-page">
        <main role="main" class="container py-4">
            <partial name="_Alerts" />
            @RenderBody()
        </main>
    </div>

    <footer class="agendapro-footer">
        <div class="container d-flex justify-content-between flex-column flex-md-row gap-2">
            <span>&copy; 2026 - AgendaPro</span>
            <span class="text-muted">Sistema de agendamento</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>