@model AgendaPro.ViewModels.AgendamentoFormViewModel

@{
    ViewData["Title"] = "Editar Agendamento";
}

<h2>Editar Agendamento</h2>

<form asp-action="Edit">

    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="ClienteId" class="form-label"></label>
        <select asp-for="ClienteId" class="form-control" asp-items="Model.Clientes">
            <option value="">Selecione o cliente</option>
        </select>
        <span asp-validation-for="ClienteId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ServicoId" class="form-label"></label>
        <select asp-for="ServicoId" class="form-control" asp-items="Model.Servicos">
            <option value="">Selecione o serviço</option>
        </select>
        <span asp-validation-for="ServicoId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ProfissionalId" class="form-label"></label>
        <select asp-for="ProfissionalId" class="form-control" asp-items="Model.Profissionais">
            <option value="">Selecione o profissional</option>
        </select>
        <span asp-validation-for="ProfissionalId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Data" class="form-label"></label>
        <input asp-for="Data" type="date" class="form-control" />
        <span asp-validation-for="Data" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="HoraInicio" class="form-label"></label>
        <input asp-for="HoraInicio" type="time" class="form-control" />
        <span asp-validation-for="HoraInicio" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Observacoes" class="form-label"></label>
        <textarea asp-for="Observacoes" class="form-control"></textarea>
        <span asp-validation-for="Observacoes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}