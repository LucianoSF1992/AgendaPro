@model IEnumerable<AgendaPro.Models.Agendamento>

@{
    ViewData["Title"] = "Agendamentos";

    var agendamentosPorData = Model
        .OrderBy(a => a.Data)
        .ThenBy(a => a.HoraInicio)
        .GroupBy(a => a.Data.Date);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Agendamentos</h2>
    <a asp-action="Create" class="btn btn-primary">Novo Agendamento</a>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">
        @TempData["Sucesso"]
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        Nenhum agendamento cadastrado.
    </div>
}
else
{
    @foreach (var grupo in agendamentosPorData)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">@grupo.Key.ToString("dddd, dd/MM/yyyy")</h5>
            </div>

            <div class="card-body p-0">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Hora</th>
                            <th>Cliente</th>
                            <th>Serviço</th>
                            <th>Profissional</th>
                            <th class="text-center">Status</th>
                            <th style="width: 220px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in grupo)
                        {
                            var dataHoraAgendamento = item.Data.Date.Add(item.HoraInicio);
                            var agendamentoPassado = dataHoraAgendamento < DateTime.Now;

                            <tr class="@(agendamentoPassado ? "table-secondary text-muted" : "")">
                                <td>@item.HoraInicio.ToString(@"hh\:mm") - @item.HoraFim.ToString(@"hh\:mm")</td>
                                <td>@item.Cliente.Nome</td>
                                <td>@item.Servico.Nome</td>
                                <td>@(item.Profissional.NomeCompleto ?? item.Profissional.Email)</td>

                                <td class="text-center">
                                    @switch (item.Status)
                                    {
                                        case "Agendado":
                                            <span class="badge bg-warning text-dark">Agendado</span>
                                            break;

                                        case "Concluido":
                                        case "Concluído":
                                            <span class="badge bg-success">Concluído</span>
                                            break;

                                        case "Cancelado":
                                            <span class="badge bg-danger">Cancelado</span>
                                            break;

                                        default:
                                            <span class="badge bg-secondary">@item.Status</span>
                                            break;
                                    }
                                </td>

                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-info text-white">Detalhes</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Excluir</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}