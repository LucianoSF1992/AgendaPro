@model IEnumerable<AgendaPro.Models.Agendamento>

@{
    ViewData["Title"] = "Agendamentos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Agendamentos</h2>
    <a asp-action="Create" class="btn btn-primary">Novo Agendamento</a>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">@TempData["Sucesso"]</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Data</th>
            <th>Hora</th>
            <th>Cliente</th>
            <th>Serviço</th>
            <th>Profissional</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Data.ToString("dd/MM/yyyy")</td>
                <td>@item.HoraInicio.ToString(@"hh\:mm") - @item.HoraFim.ToString(@"hh\:mm")</td>
                <td>@item.Cliente.Nome</td>
                <td>@item.Servico.Nome</td>
                <td>@(item.Profissional.NomeCompleto ?? item.Profissional.Email)
                </td>
                <td>@item.Status</td>
            </tr>
        }
    </tbody>
</table>