@model IEnumerable<AgendaPro.Models.Agendamento>

@{
    ViewData["Title"] = "Agendamentos";

    var agendamentosPorData = Model
        .OrderBy(a => a.Data)
        .ThenBy(a => a.HoraInicio)
        .GroupBy(a => a.Data.Date);
}

<section class="py-2">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <span class="badge bg-primary-subtle text-primary mb-2 px-3 py-2 rounded-pill">
                Agenda de atendimentos
            </span>
            <h2 class="mb-1">Agendamentos</h2>
            <p class="text-muted mb-0">Acompanhe os horários cadastrados e gerencie os atendimentos do sistema.</p>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div>
                <a asp-action="Create" class="btn btn-primary px-4">
                    Novo Agendamento
                </a>
            </div>
        }
    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success mb-4">
            @TempData["Sucesso"]
        </div>
    }

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger mb-4">
            @TempData["Erro"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="alert alert-info mb-0">
                    Nenhum agendamento cadastrado.
                </div>
            </div>
        </div>
    }
    else
    {
        @foreach (var grupo in agendamentosPorData)
        {
            <div class="card mb-4 shadow-sm border-0 rounded-4">
                <div class="card-header bg-light py-3 px-4">
                    <h5 class="mb-0 fw-bold text-capitalize">@grupo.Key.ToString("dddd, dd/MM/yyyy")</h5>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th class="ps-4">Hora</th>
                                    <th>Cliente</th>
                                    <th>Serviço</th>
                                    <th>Profissional</th>
                                    <th class="text-center">Status Atual</th>
                                    <th class="text-center">Atualizar Status</th>
                                    <th class="text-center pe-4 agendapro-table-actions" style="width: 220px;">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in grupo)
                                {
                                    var dataHoraAgendamento = item.Data.Date.Add(item.HoraInicio);
                                    var agendamentoPassado = dataHoraAgendamento < DateTime.Now;

                                    <tr class="@(agendamentoPassado ? "table-secondary text-muted" : "")">
                                        <td class="ps-4 fw-semibold">
                                            @item.HoraInicio.ToString(@"hh\:mm") - @item.HoraFim.ToString(@"hh\:mm")
                                        </td>
                                        <td>@item.Cliente.Nome</td>
                                        <td>@item.Servico.Nome</td>
                                        <td>@(item.Profissional.NomeCompleto ?? item.Profissional.Email)</td>

                                        <td class="text-center">
                                            @switch (item.Status)
                                            {
                                                case "Agendado":
                                                    <span class="badge bg-warning text-dark">Agendado</span>
                                                    break;

                                                case "Concluido":
                                                case "Concluído":
                                                    <span class="badge bg-success">Concluído</span>
                                                    break;

                                                case "Cancelado":
                                                    <span class="badge bg-danger">Cancelado</span>
                                                    break;

                                                default:
                                                    <span class="badge bg-secondary">@item.Status</span>
                                                    break;
                                            }
                                        </td>

                                        <td class="text-center">
                                            <form asp-action="AtualizarStatus" method="post" class="d-flex flex-column flex-md-row justify-content-center gap-2 agendapro-status-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />

                                                <select name="status" class="form-select form-select-sm">
                                                    <option value="Agendado" selected="@(item.Status == "Agendado")">Agendado</option>
                                                    <option value="Concluído" selected="@(item.Status == "Concluído" || item.Status == "Concluido")">Concluído</option>
                                                    <option value="Cancelado" selected="@(item.Status == "Cancelado")">Cancelado</option>
                                                </select>

                                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                                    Salvar
                                                </button>
                                            </form>
                                        </td>

                                        <td class="text-center pe-4">
                                            <div class="d-flex flex-wrap justify-content-center gap-2">
                                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                                    Detalhes
                                                </a>

                                                @if (User.IsInRole("Admin"))
                                                {
                                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                                        Editar
                                                    </a>
                                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                                        Excluir
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</section>