@model AgendaPro.Models.Servico

@{
    ViewData["Title"] = "Editar Serviço";
}

<div class="container py-4">
    <h1 class="mb-4">Editar Serviço</h1>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="DuracaoEmMinutos" class="form-label"></label>
            <input asp-for="DuracaoEmMinutos" class="form-control" />
            <span asp-validation-for="DuracaoEmMinutos" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ValorPadrao" class="form-label"></label>
            <input asp-for="ValorPadrao" class="form-control" />
            <span asp-validation-for="ValorPadrao" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Observacoes" class="form-label"></label>
            <textarea asp-for="Observacoes" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Observacoes" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Salvar Alterações</button>
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}