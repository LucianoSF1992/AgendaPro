@model AgendaPro.Models.Servico

@{
    ViewData["Title"] = "Excluir Serviço";
}

<div class="container py-4">
    <h1 class="mb-4 text-danger">Excluir Serviço</h1>

    <div class="alert alert-warning">
        Tem certeza que deseja excluir este serviço?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Nome</dt>
        <dd class="col-sm-9">@Model.Nome</dd>

        <dt class="col-sm-3">Duração</dt>
        <dd class="col-sm-9">@Model.DuracaoEmMinutos min</dd>

        <dt class="col-sm-3">Valor padrão</dt>
        <dd class="col-sm-9">@Model.ValorPadrao.ToString("C")</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>